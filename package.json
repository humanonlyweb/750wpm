    "dexie": "^4.4.1",
    "fflate": "^0.8.2",
    "nuxt": "^4.4.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "sass-embedded": "^1.98.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
