    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@nuxt/fonts": "0.12.1",
    "@vite-pwa/nuxt": "1.1.0",
    "dexie": "^4.3.0",
    "fflate": "^0.8.2",
    "nuxt": "^4.4.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.17.0",
    "sass-embedded": "^1.98.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue}": [
