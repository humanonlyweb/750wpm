{
  "name": "750wpm",
  "workers_dev": false,
  "compatibility_date": "2026-03-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./.output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": "./.output/public/",
  },
  "routes": [
    {
      "pattern": "750wpm.com",
      "custom_domain": true,
    },
  ],
}
